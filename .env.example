# Phone Agent local configuration example.
# Copy to an untracked file and export the values before running scripts.

PHONE_AGENT_SPRING_BIND_ADDRESS=127.0.0.1
PHONE_AGENT_SPRING_PORT=8080
PHONE_AGENT_SPRING_URL=http://127.0.0.1:8080
PHONE_AGENT_CALLBACK_URL=http://host.docker.internal:8080

PHONE_AGENT_MYSQL_HOST=127.0.0.1
PHONE_AGENT_MYSQL_PORT=3307
PHONE_AGENT_MYSQL_DATABASE=phone_agent
PHONE_AGENT_MYSQL_USER=root
PHONE_AGENT_MYSQL_PASSWORD=change-me

PHONE_AGENT_AMI_HOST=127.0.0.1
PHONE_AGENT_AMI_PORT=5038
PHONE_AGENT_AMI_USER=phone-agent
PHONE_AGENT_AMI_SECRET=change-me

PHONE_AGENT_SIP_EXTENSION=1001
PHONE_AGENT_SIP_AUTH_ID=1001
PHONE_AGENT_SIP_PASSWORD=1001
PHONE_AGENT_RING_TARGET=PJSIP/1001
PHONE_AGENT_BLF_EVENTLIST_URI=phone-agent-slots
PHONE_AGENT_BLF_EXTENSIONS=601,602,603,604,605,606,607,608
PHONE_AGENT_ASTERISK_EXTERNAL_SIGNALING_ADDRESS=192.168.10.1
PHONE_AGENT_ASTERISK_EXTERNAL_MEDIA_ADDRESS=192.168.10.1

PHONE_AGENT_CODEX_COMMAND=codex
PHONE_AGENT_TMUX_COMMAND=tmux
PHONE_AGENT_TTYD_COMMAND=ttyd
PHONE_AGENT_CODEX_PROMPT_LANGUAGE=zh-CN

PHONE_AGENT_RUNTIME_DIR=runtime
PHONE_AGENT_FFMPEG_COMMAND=ffmpeg
PHONE_AGENT_WHISPER_COMMAND=whisper
PHONE_AGENT_WHISPER_MODEL_PATH=models/whisper/ggml-small.bin
PHONE_AGENT_ASR_LANGUAGE=zh
PHONE_AGENT_SAY_COMMAND=say

# Optional local JDK override for scripts.
JAVA_HOME=/path/to/jdk
